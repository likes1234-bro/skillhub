# `edge` tracks the latest build from the default branch.
# For deterministic environments, pin a release tag like `v0.1.0`.
SKILLHUB_VERSION=edge
SKILLHUB_SERVER_IMAGE=crpi-ptu2rqimrigtq0qx.cn-hangzhou.personal.cr.aliyuncs.com/test1245/iflytek_skillhub-server
SKILLHUB_WEB_IMAGE=crpi-ptu2rqimrigtq0qx.cn-hangzhou.personal.cr.aliyuncs.com/test1245/iflytek_skillhub-web
POSTGRES_IMAGE=crpi-ptu2rqimrigtq0qx.cn-hangzhou.personal.cr.aliyuncs.com/test1245/postgres:16-alpine
REDIS_IMAGE=crpi-ptu2rqimrigtq0qx.cn-hangzhou.personal.cr.aliyuncs.com/test1245/redis:7-alpine

POSTGRES_PORT=5432
POSTGRES_DB=skillhub
POSTGRES_USER=skillhub
POSTGRES_PASSWORD=skillhub_demo

REDIS_PORT=6379
API_PORT=8080
WEB_PORT=80

# Optional: configure real GitHub OAuth before exposing the stack to other users.
OAUTH2_GITHUB_CLIENT_ID=local-placeholder
OAUTH2_GITHUB_CLIENT_SECRET=local-placeholder
